#!/usr/bin/env bash
#
# exe.dev VM bootstrap
#
# Usage:
#   cat ~/dotfiles/exe.dev/setup | ssh exe.dev new --name=dev-vm --setup-script=/dev/stdin
#
# Or against an existing VM:
#   cat ~/dotfiles/exe.dev/setup | ssh dev-vm.exe.xyz bash -s
#
set -euo pipefail

DOTFILES_DIR="$HOME/dotfiles"
GITHUB_DIR="$HOME/github"
MISE_BIN="$HOME/.local/bin/mise"

# exe.dev GitHub integration hostnames (see exe.dev ▶ integrations list)
# Repos are cloneable without tokens via these hosts:
DOTFILES_URL="https://damonkelley-dotfiles.int.exe.xyz/damonkelley/dotfiles.git"
PI_CONFIG_URL="https://damonkelley-pi-config.int.exe.xyz/damonkelley/pi-config.git"

log()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*" >&2; }

# ---------------------------------------------------------------------------
# 1. System packages
# ---------------------------------------------------------------------------
log "Installing system packages"
sudo apt-get update -qq
sudo apt-get install -y -qq \
  zsh git jq curl wget gh ca-certificates \
  fonts-firacode build-essential \
  >/dev/null
sudo apt-get autoremove -y -qq >/dev/null

# ---------------------------------------------------------------------------
# 2. Shell
# ---------------------------------------------------------------------------
log "Setting zsh as default shell"
if [ "$(getent passwd "$USER" | cut -d: -f7)" != "$(command -v zsh)" ]; then
  sudo chsh -s "$(command -v zsh)" "$USER"
fi

# ---------------------------------------------------------------------------
# 3. mise + tools
# ---------------------------------------------------------------------------
log "Installing mise"
if [ ! -x "$MISE_BIN" ]; then
  curl -fsSL https://mise.run | sh
fi

# mise shims must be on PATH so `bun`, `node`, etc. resolve below
export PATH="$HOME/.local/bin:$HOME/.local/share/mise/shims:$PATH"

log "Installing mise tools"
mise use -g babashka@latest
mise use -g bat@latest
mise use -g bun@latest
mise use -g direnv@latest
mise use -g eza@latest
mise use -g fd@latest
mise use -g fzf@latest
mise use -g neovim@latest
mise use -g node@latest
mise use -g ripgrep@latest
mise use -g rust@latest
mise use -g starship@latest
mise use -g tmux@latest
mise use -g zellij@latest

# ---------------------------------------------------------------------------
# 4. Dotfiles
# ---------------------------------------------------------------------------
log "Cloning dotfiles via GitHub integration"
if [ ! -d "$DOTFILES_DIR/.git" ]; then
  git clone --quiet "$DOTFILES_URL" "$DOTFILES_DIR"
else
  git -C "$DOTFILES_DIR" pull --quiet
fi

log "Linking dotfiles"
mkdir -p "$HOME/.config"
ln -sfvn "$DOTFILES_DIR/nvim"            "$HOME/.config/nvim"
ln -sfvn "$DOTFILES_DIR/ghostty"         "$HOME/.config/ghostty"
ln -sfvn "$DOTFILES_DIR/alacritty"       "$HOME/.config/alacritty"
ln -sfvn "$DOTFILES_DIR/zellij"          "$HOME/.config/zellij"
ln -sfvn "$DOTFILES_DIR/bin"             "$HOME/.bin"
ln -sfv  "$DOTFILES_DIR/starship/starship.toml" "$HOME/.config/starship.toml"
ln -sfv  "$DOTFILES_DIR/idea/ideavimrc"  "$HOME/.ideavimrc"
ln -sfv  "$DOTFILES_DIR/tmux/tmux.conf"  "$HOME/.tmux.conf"
ln -sfv  "$DOTFILES_DIR/git/gitconfig"   "$HOME/.gitconfig"
ln -sfv  "$DOTFILES_DIR/git/gitignore_global" "$HOME/.gitignore_global"
ln -sfv  "$DOTFILES_DIR/zsh/zshrc"       "$HOME/.zshrc"

# ---------------------------------------------------------------------------
# 5. Projects + pi
# ---------------------------------------------------------------------------
# Note: pi itself is already installed on exeuntu VMs. We keep the box's naive
# pi config (exe.dev context, theme, etc.) and only add pi-config as a package.

log "Setting up projects"
mkdir -p "$GITHUB_DIR"

log "Cloning pi-config via GitHub integration"
if [ ! -d "$GITHUB_DIR/pi-config/.git" ]; then
  git clone --quiet "$PI_CONFIG_URL" "$GITHUB_DIR/pi-config" \
    || warn "Could not clone pi-config — check your exe.dev GitHub integration"
fi

# Link the `web` CLI
if [ -f "$GITHUB_DIR/pi-config/packages/web/package.json" ]; then
  log "Linking web CLI"
  (cd "$GITHUB_DIR/pi-config/packages/web" && bun install --quiet && bun link)
fi

# Merge pi-config into ~/.pi/agent/settings.json packages, preserving everything
# else (naive exe.dev config, theme, lastChangelogVersion, provider, etc.).
# Idempotent: skips if already present.
log "Registering pi-config package in pi settings"
SETTINGS="$HOME/.pi/agent/settings.json"
mkdir -p "$(dirname "$SETTINGS")"
[ -f "$SETTINGS" ] || echo '{}' > "$SETTINGS"
TMP=$(mktemp)
jq --arg p "$GITHUB_DIR/pi-config" \
   '.packages = ((.packages // []) | if index($p) then . else . + [$p] end)' \
   "$SETTINGS" > "$TMP" && mv "$TMP" "$SETTINGS"

# ---------------------------------------------------------------------------
# 6. Done
# ---------------------------------------------------------------------------
cat <<EOF

\033[1;32m=== Setup complete ===\033[0m

  Shell:       zsh  (run \`zsh\` to activate)
  Dotfiles:    $DOTFILES_DIR
  Projects:    $GITHUB_DIR
  pi-config:   $GITHUB_DIR/pi-config
EOF
